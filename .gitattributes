# Normalize line endings; let git decide text vs binary by default.
* text=auto

# Windows-toolchain files stay CRLF.
*.sln      text eol=crlf
*.slnx     text eol=crlf
*.csproj   text eol=crlf
*.props    text eol=crlf
*.targets  text eol=crlf
*.vcxproj  text eol=crlf
*.ps1      text eol=crlf
*.cmd      text eol=crlf
*.bat      text eol=crlf

# Source stays LF.
*.cs       text eol=lf
*.cpp      text eol=lf
*.h        text eol=lf
*.hpp      text eol=lf
*.cmake    text eol=lf
CMakeLists.txt text eol=lf

# Binary artifacts.
*.dll      binary
*.lib      binary
*.exp      binary
*.pdb      binary
*.ico      binary
